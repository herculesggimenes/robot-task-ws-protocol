{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-task-ws-protocol.dev/schemas/image-frame.schema.json",
  "title": "RobotImageFrame",
  "type": "object",
  "required": [
    "type",
    "protocol",
    "version",
    "frame_id",
    "camera_id",
    "content_type",
    "encoding",
    "data"
  ],
  "additionalProperties": true,
  "properties": {
    "type": { "const": "image.frame" },
    "protocol": { "const": "robot-task-ws" },
    "version": { "type": "string" },
    "frame_id": { "type": "string", "minLength": 1 },
    "camera_id": { "type": "string", "minLength": 1 },
    "content_type": { "type": "string" },
    "encoding": { "enum": ["base64"] },
    "captured_at": { "type": "number" },
    "sent_at": { "type": "number" },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "data": { "type": "string" },
    "depth": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
